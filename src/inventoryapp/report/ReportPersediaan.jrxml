<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="persediaan" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="30" bottomMargin="30">
    <style name="TableCell" fontName="SansSerif" fontSize="9" forecolor="#243247"/><style name="TableHeader" fontName="SansSerif" fontSize="9" isBold="true" forecolor="#475569" backcolor="#EAF0F7" mode="Opaque"/><style name="Muted" fontName="SansSerif" fontSize="9" forecolor="#64748B"/>
    <parameter name="REPORT_GENERATED_AT" class="java.util.Date"/><parameter name="REPORT_SCOPE" class="java.lang.String"/>
    <queryString language="SQL"><![CDATA[SELECT b.kode, b.nama, k.nama AS kategori, b.satuan, b.stok FROM tmbarang b INNER JOIN tmkategori k ON k.id = b.id_kategori ORDER BY b.kode]]></queryString>
    <field name="kode" class="java.lang.String"/><field name="nama" class="java.lang.String"/><field name="kategori" class="java.lang.String"/><field name="satuan" class="java.lang.String"/><field name="stok" class="java.lang.Integer"/>
    <variable name="TOTAL_STOK" class="java.lang.Integer" calculation="Sum"><variableExpression><![CDATA[$F{stok}]]></variableExpression></variable>
    <title><band height="126"><rectangle><reportElement x="0" y="0" width="515" height="82" backcolor="#1E3A5F" mode="Opaque"/><graphicElement/></rectangle><staticText><reportElement x="22" y="18" width="300" height="28" forecolor="#FFFFFF"/><textElement><font fontName="SansSerif" size="19" isBold="true"/></textElement><text><![CDATA[Laporan Persediaan]]></text></staticText><staticText><reportElement x="22" y="48" width="300" height="17" forecolor="#DCE7F4"/><textElement><font fontName="SansSerif" size="10"/></textElement><text><![CDATA[Rangkuman stok barang yang tersedia saat ini]]></text></staticText><staticText><reportElement x="22" y="96" width="100" height="14"/><textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement><text><![CDATA[CAKUPAN DATA]]></text></staticText><textField><reportElement x="22" y="110" width="220" height="14"/><textElement><font fontName="SansSerif" size="10"/></textElement><textFieldExpression><![CDATA[$P{REPORT_SCOPE}]]></textFieldExpression></textField><staticText><reportElement x="310" y="96" width="120" height="14"/><textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement><text><![CDATA[DIBUAT PADA]]></text></staticText><textField pattern="dd MMMM yyyy, HH:mm"><reportElement x="310" y="110" width="190" height="14"/><textElement><font fontName="SansSerif" size="10"/></textElement><textFieldExpression><![CDATA[$P{REPORT_GENERATED_AT}]]></textFieldExpression></textField></band></title>
    <columnHeader><band height="28"><staticText><reportElement style="TableHeader" x="0" y="4" width="78" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[KODE]]></text></staticText><staticText><reportElement style="TableHeader" x="78" y="4" width="180" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[NAMA BARANG]]></text></staticText><staticText><reportElement style="TableHeader" x="258" y="4" width="120" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[KATEGORI]]></text></staticText><staticText><reportElement style="TableHeader" x="378" y="4" width="80" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[SATUAN]]></text></staticText><staticText><reportElement style="TableHeader" x="458" y="4" width="57" height="20"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[STOK]]></text></staticText></band></columnHeader>
    <detail><band height="24"><textField textAdjust="StretchHeight"><reportElement style="TableCell" x="0" y="3" width="78" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{kode}]]></textFieldExpression></textField><textField textAdjust="StretchHeight"><reportElement style="TableCell" x="78" y="3" width="180" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression></textField><textField textAdjust="StretchHeight"><reportElement style="TableCell" x="258" y="3" width="120" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{kategori}]]></textFieldExpression></textField><textField><reportElement style="TableCell" x="378" y="3" width="80" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{satuan}]]></textFieldExpression></textField><textField pattern="#,##0"><reportElement style="TableCell" x="458" y="3" width="57" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{stok}]]></textFieldExpression></textField><line><reportElement x="0" y="23" width="515" height="1" forecolor="#E2E8F0"/></line></band></detail>
    <pageFooter><band height="22"><line><reportElement x="0" y="1" width="515" height="1" forecolor="#E2E8F0"/></line><staticText><reportElement style="Muted" x="0" y="7" width="270" height="12"/><text><![CDATA[Inventory App - Dokumen internal]]></text></staticText><textField><reportElement style="Muted" x="390" y="7" width="125" height="12"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band></pageFooter>
