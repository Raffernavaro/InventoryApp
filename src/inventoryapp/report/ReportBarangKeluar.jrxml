<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="barang_keluar" pageWidth="595" pageHeight="842" columnWidth="515" leftMargin="40" rightMargin="40" topMargin="30" bottomMargin="30">
    <style name="TableCell" fontName="SansSerif" fontSize="9" forecolor="#243247"/><style name="TableHeader" fontName="SansSerif" fontSize="9" isBold="true" forecolor="#475569" backcolor="#EAF0F7" mode="Opaque"/><style name="Muted" fontName="SansSerif" fontSize="9" forecolor="#64748B"/>
    <parameter name="REPORT_GENERATED_AT" class="java.util.Date"/><parameter name="REPORT_SCOPE" class="java.lang.String"/>
    <queryString language="SQL"><![CDATA[SELECT k.tgl, b.kode, b.nama AS barang, p.nama AS pelanggan, d.jumlah FROM trbarang_keluar k INNER JOIN trbarang_keluar_detail d ON d.id_barang_keluar = k.id INNER JOIN tmbarang b ON b.id = d.id_barang INNER JOIN tmpelanggan p ON p.id = k.id_pelanggan ORDER BY k.tgl DESC, k.id DESC]]></queryString>
    <field name="tgl" class="java.sql.Date"/><field name="kode" class="java.lang.String"/><field name="barang" class="java.lang.String"/><field name="pelanggan" class="java.lang.String"/><field name="jumlah" class="java.lang.Integer"/>
    <variable name="TOTAL_JUMLAH" class="java.lang.Integer" calculation="Sum"><variableExpression><![CDATA[$F{jumlah}]]></variableExpression></variable>
    <title><band height="126"><rectangle><reportElement x="0" y="0" width="515" height="82" backcolor="#1E3A5F" mode="Opaque"/><graphicElement/></rectangle><staticText><reportElement x="22" y="18" width="300" height="28" forecolor="#FFFFFF"/><textElement><font fontName="SansSerif" size="19" isBold="true"/></textElement><text><![CDATA[Laporan Barang Keluar]]></text></staticText><staticText><reportElement x="22" y="48" width="330" height="17" forecolor="#DCE7F4"/><textElement><font fontName="SansSerif" size="10"/></textElement><text><![CDATA[Rekap penyaluran barang kepada pelanggan]]></text></staticText><staticText><reportElement x="22" y="96" width="100" height="14"/><textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement><text><![CDATA[CAKUPAN DATA]]></text></staticText><textField><reportElement x="22" y="110" width="220" height="14"/><textElement><font fontName="SansSerif" size="10"/></textElement><textFieldExpression><![CDATA[$P{REPORT_SCOPE}]]></textFieldExpression></textField><staticText><reportElement x="310" y="96" width="120" height="14"/><textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement><text><![CDATA[DIBUAT PADA]]></text></staticText><textField pattern="dd MMMM yyyy, HH:mm"><reportElement x="310" y="110" width="190" height="14"/><textElement><font fontName="SansSerif" size="10"/></textElement><textFieldExpression><![CDATA[$P{REPORT_GENERATED_AT}]]></textFieldExpression></textField></band></title>
    <columnHeader><band height="28"><staticText><reportElement style="TableHeader" x="0" y="4" width="82" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[TANGGAL]]></text></staticText><staticText><reportElement style="TableHeader" x="82" y="4" width="65" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[KODE]]></text></staticText><staticText><reportElement style="TableHeader" x="147" y="4" width="140" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[BARANG]]></text></staticText><staticText><reportElement style="TableHeader" x="287" y="4" width="165" height="20"/><textElement verticalAlignment="Middle"/><text><![CDATA[PELANGGAN]]></text></staticText><staticText><reportElement style="TableHeader" x="452" y="4" width="63" height="20"/><textElement textAlignment="Right" verticalAlignment="Middle"/><text><![CDATA[JML.]]></text></staticText></band></columnHeader>
    <detail><band height="24"><textField pattern="dd MMM yyyy"><reportElement style="TableCell" x="0" y="3" width="82" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{tgl}]]></textFieldExpression></textField><textField><reportElement style="TableCell" x="82" y="3" width="65" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{kode}]]></textFieldExpression></textField><textField textAdjust="StretchHeight"><reportElement style="TableCell" x="147" y="3" width="140" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{barang}]]></textFieldExpression></textField><textField textAdjust="StretchHeight"><reportElement style="TableCell" x="287" y="3" width="165" height="18"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{pelanggan}]]></textFieldExpression></textField><textField pattern="#,##0"><reportElement style="TableCell" x="452" y="3" width="63" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{jumlah}]]></textFieldExpression></textField><line><reportElement x="0" y="23" width="515" height="1" forecolor="#E2E8F0"/></line></band></detail>
    <pageFooter><band height="22"><line><reportElement x="0" y="1" width="515" height="1" forecolor="#E2E8F0"/></line><staticText><reportElement style="Muted" x="0" y="7" width="270" height="12"/><text><![CDATA[Inventory App - Dokumen internal]]></text></staticText><textField><reportElement style="Muted" x="390" y="7" width="125" height="12"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band></pageFooter>
    <summary><band height="70"><rectangle><reportElement x="0" y="10" width="245" height="46" backcolor="#EEF6FF" mode="Opaque"/><graphicElement/></rectangle><staticText><reportElement x="14" y="18" width="140" height="13"/><textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement><text><![CDATA[ITEM PENYALURAN]]></text></staticText><textField><reportElement x="14" y="31" width="180" height="20"/><textElement><font fontName="SansSerif" size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression></textField><rectangle><reportElement x="270" y="10" width="245" height="46" backcolor="#EEF6FF" mode="Opaque"/><graphicElement/></rectangle><staticText><reportElement x="284" y="18" width="140" height="13"/><textElement><font fontName="SansSerif" size="8" isBold="true"/></textElement><text><![CDATA[TOTAL UNIT KELUAR]]></text></staticText><textField pattern="#,##0"><reportElement x="284" y="31" width="180" height="20"/><textElement><font fontName="SansSerif" size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$V{TOTAL_JUMLAH}]]></textFieldExpression></textField></band></summary>
